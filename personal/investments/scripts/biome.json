{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "style": {
        "noParameterAssign": "off",
        "noNonNullAssertion": "error",
        "useTemplate": "off"
      }
    }
  },
  "files": {
    "ignore": ["../data/**", "../notes/**", "src/ledger.js"]
  }
}
